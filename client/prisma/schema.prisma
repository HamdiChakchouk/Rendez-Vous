generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Salon {
  id                 String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nom_salon          String
  adresse            String
  telephone          String
  description        String?
  horaires_ouverture Json?
  qr_code_url        String?
  logo_url           String?
  photos             Json?        @default("[]")
  social_networks    Json?        @default("{}")
  service_area       String[]     @default([])
  created_at         DateTime     @default(now()) @db.Timestamptz(6)
  updated_at         DateTime     @default(now()) @db.Timestamptz(6)
  absences           Absence[]
  admins             Admin[]
  employes           Employe[]
  rendez_vous        RendezVous[]
  reviews            Review[]
  services           Service[]
  waitlist           Waitlist[]

  @@map("salons")
}

model Service {
  id            String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  salon_id      String       @db.Uuid
  nom_service   String
  duree_minutes Int
  prix               Decimal      @db.Decimal(10, 2)
  genre_cible        String[]     @default(["Unisexe"])
  photos_exemples    Json?        @default("[]")
  created_at         DateTime     @default(now()) @db.Timestamptz(6)
  updated_at         DateTime     @default(now()) @db.Timestamptz(6)
  absences           Absence[]
  rendez_vous        RendezVous[]
  salon         Salon        @relation(fields: [salon_id], references: [id], onDelete: Cascade)
  waitlist      Waitlist[]

  @@index([salon_id])
  @@map("services")
}

model Employe {
  id                   String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id              String?      @unique @db.Uuid
  salon_id             String       @db.Uuid
  nom_employe          String
  services_disponibles String[]     @default([]) @db.Uuid
  created_at           DateTime     @default(now()) @db.Timestamptz(6)
  updated_at           DateTime     @default(now()) @db.Timestamptz(6)
  salon                Salon        @relation(fields: [salon_id], references: [id], onDelete: Cascade)
  absences             Absence[]
  rendez_vous          RendezVous[]

  @@index([salon_id])
  @@map("employes")
}

model Client {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nom_client  String?
  telephone   String       @unique
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  updated_at  DateTime     @default(now()) @db.Timestamptz(6)
  is_blocked  Boolean      @default(false)
  risk_score  Float        @default(0.0)
  rendez_vous RendezVous[]
  reviews     Review[]
  waitlist    Waitlist[]

  @@map("clients")
}

model RendezVous {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  salon_id      String    @db.Uuid
  employe_id    String?   @db.Uuid
  client_id     String    @db.Uuid
  service_id    String    @db.Uuid
  date_rdv      DateTime  @db.Date
  heure_rdv     DateTime  @db.Time(6)
  statut        String    @default("pending")
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @db.Timestamptz(6)
  cancel_reason String?
  cancelled_by  String?
  confirmed_at  DateTime? @db.Timestamptz(6)
  client        Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  employe       Employe?  @relation(fields: [employe_id], references: [id])
  salon         Salon     @relation(fields: [salon_id], references: [id], onDelete: Cascade)
  service       Service   @relation(fields: [service_id], references: [id], onDelete: Cascade)
  reviews       Review[]

  @@index([salon_id])
  @@index([client_id])
  @@index([employe_id])
  @@index([date_rdv])
  @@map("rendez_vous")
}

model OtpCustom {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  telephone       String
  code_otp        String
  date_expiration DateTime @db.Timestamptz(6)
  verified        Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  @@map("otp_custom")
}

model Admin {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id           String?  @unique @db.Uuid
  nom_admin         String
  email             String   @unique
  mot_de_passe_hash String
  role              String   @default("manager")
  salon_id          String?  @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)
  salon             Salon?   @relation(fields: [salon_id], references: [id])

  @@map("admins")
}

model Review {
  id             String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  rendez_vous_id String     @db.Uuid
  client_id      String     @db.Uuid
  salon_id       String     @db.Uuid
  rating         Int
  commentaire    String?
  created_at     DateTime   @default(now()) @db.Timestamptz(6)
  client         Client     @relation(fields: [client_id], references: [id], onDelete: Cascade)
  rendez_vous    RendezVous @relation(fields: [rendez_vous_id], references: [id], onDelete: Cascade)
  salon          Salon      @relation(fields: [salon_id], references: [id], onDelete: Cascade)

  @@index([salon_id])
  @@index([client_id])
  @@map("reviews")
}

model Waitlist {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  client_id      String   @db.Uuid
  salon_id       String   @db.Uuid
  service_id     String   @db.Uuid
  date_souhaitee DateTime @db.Date
  statut         String   @default("waiting")
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  client         Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  salon          Salon    @relation(fields: [salon_id], references: [id], onDelete: Cascade)
  service        Service  @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@index([salon_id])
  @@index([client_id])
  @@map("waitlist")
}

model Absence {
  id                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employe_id        String   @db.Uuid
  salon_id          String   @db.Uuid
  service_id        String?  @db.Uuid
  type              String   // Congé annuel, Maladie, etc.
  date_debut        DateTime @db.Date
  date_fin          DateTime @db.Date
  is_half_day       Boolean  @default(false)
  commentaire       String?
  piece_jointe_url  String?
  statut            String   @default("pending") // pending, approved, rejected
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)
  employe           Employe  @relation(fields: [employe_id], references: [id], onDelete: Cascade)
  salon             Salon    @relation(fields: [salon_id], references: [id], onDelete: Cascade)
  service           Service? @relation(fields: [service_id], references: [id])

  @@index([salon_id])
  @@index([employe_id])
  @@map("absences")
}
